local function setLock(lock)
	if lock then
		if accTwn then accTwn:Cancel() end
		hum.WalkSpeed, hum.JumpPower, hum.JumpHeight = 0, 0, 0
		hum.AutoRotate = false
	else
		hum.AutoRotate = (lockedTarget == nil)
		hum.JumpPower, hum.JumpHeight = J_PWR, J_HGT
		hum.WalkSpeed = B_SPD
	end
end

local function updMov(speed)
	if isAtk or isSpec then return end
	
	local state = hum:GetState()
	
	if state == Enum.HumanoidStateType.Jumping then
		if cState ~= "Jumping" then
			cState = "Jumping"
			pAnim(Anims.Jump, 1, false, true, 0.1)
		end
		return
	elseif state == Enum.HumanoidStateType.Freefall then
		if cState ~= "Freefall" then
			cState = "Freefall"
			pAnim(Anims.Fall, 1, true, false, 0.1)
		end
		return
	end

	if speed > 0.5 then
		if cState == "Idle" or cState == "Jumping" or cState == "Freefall" then
			cState = "Walking"
			pAnim(Anims.Walk, 1, true, false, 0.2)
			hum.WalkSpeed = B_SPD
			if accTwn then accTwn:Cancel() end
			accTwn = TS:Create(hum, TweenInfo.new(ACC_T, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {WalkSpeed = M_SPD})
			accTwn:Play()
		end
		
		if hum.WalkSpeed > 13 and cState ~= "Running" then
			cState = "Running"
			pAnim(Anims.Run, 1.2, true, false, 0.2)
		elseif hum.WalkSpeed <= 13 and cState ~= "Walking" then
			cState = "Walking"
			pAnim(Anims.Walk, 1, true, false, 0.2)
		end
	else
		if cState ~= "Idle" then
			cState = "Idle"
			if accTwn then accTwn:Cancel() end
			hum.WalkSpeed = B_SPD
			pAnim(Anims.Idle, 1, true, false, 0.2)
		end
	end
end

hum.Running:Connect(updMov)

