			else
				targetCF = CFrame.new(oPart.Position + rot.Position, oPart.Position)
			end
			cRoot.CFrame = targetCF
		end)
		
		local glt = game:GetService("SoundService"):FindFirstChild("Glitch") or tRoot:FindFirstChildWhichIsA("Sound")
		if glt then pSound(glt.SoundId, cRoot, 1, rng:NextInteger(115, 170) * 0.001) end
		
		if anim then
			local idx = rng:NextInteger(1, 2)
			local trackObj = script:FindFirstChild("AfterImage" .. idx)
			if trackObj then
				local track = anim:LoadAnimation(trackObj)
				track:Play(0, nil, 2)
				track.Stopped:Once(function()
					track:Play(0, nil, 0)
					track.TimePosition = track.Length - 0.001
				end)
				
				task.delay(0.1, function()
					conn:Disconnect()
					track:AdjustSpeed(0.5)
					
					local slsh = game:GetService("SoundService"):FindFirstChild("Knife_Slash")
