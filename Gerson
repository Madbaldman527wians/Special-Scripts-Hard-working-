-- ========== PARSER DE FRAMES & MOTOR ==========
local function toTab(kfs)
	if not (kfs and typeof(kfs) == "Instance" and kfs:IsA("KeyframeSequence")) then
		if typeof(kfs) == "Instance" then
			for _, obj in ipairs(kfs:GetDescendants()) do
				if obj:IsA("KeyframeSequence") then kfs = obj break end
			end
		end
	end
	assert(kfs and typeof(kfs) == "Instance" and kfs:IsA("KeyframeSequence"), "Sequencia Invalida")

	local seq = {}
	for _, frame in ipairs(kfs:GetKeyframes()) do
		local entry = { Time = frame.Time, Data = {} }
		for _, pose in ipairs(frame:GetDescendants()) do
			if pose:IsA("Pose") and pose.Weight > 0 then
				entry.Data[pose.Name] = { CFrame = pose.CFrame }
			end
		end
		table.insert(seq, entry)
	end
	table.sort(seq, function(a, b) return a.Time < b.Time end)
	return seq, kfs.Loop
end

local function bMap(rig)
	local map, low = {}, {}
	for _, m in ipairs(rig:GetDescendants()) do
		if m:IsA("Motor6D") then
			map[m.Name] = m
			low[string.lower(m.Name)] = m
		end
	end
	return map, low
end

local function fMotor(pName, map, low)
	local match = R6M[pName] or pName
	return map[match] or low[string.lower(match)]
end

-- ========== REPRODUTOR DE ANIMS (6D) ==========
local APlay = {}
APlay.__index = APlay

function APlay.new(rig, kfs)
	local self = setmetatable({}, APlay)
	self.rig = rig
	self.seq, self.looped = toTab(kfs)
	self.map, self.low = bMap(rig)
	self.time, self.playing = 0, false
	self.length = self.seq[#self.seq].Time
	self.speed = 1
	self.freezeOnEnd = false
	return self
end

function APlay:Play(speed, loop, freeze, fade)
	if self.playing then return end
	self.playing, self.speed = true, speed or 1
	self.looped = (loop == nil) and self.looped or loop
	self.freezeOnEnd = freeze or false
	
	local fDur = fade or 0.15
	local elap = 0
	local init = {}
	
	for name, motor in pairs(self.map) do
		init[name] = motor.Transform
	end

	self.conn = RS.Heartbeat:Connect(function(dt)
		if not self.playing then return end
		self.time += dt * self.speed
		elap += dt

		if self.time > self.length then
			if self.looped then
				self.time -= self.length
			elseif self.freezeOnEnd then
				self.time = self.length
			else
				self:Stop(true)
				return
			end
		end

		local f1, f2 = self.seq[1], self.seq[1]
		for i = 1, #self.seq do
			if self.seq[i].Time <= self.time then
				f1 = self.seq[i]
			else
				f2 = self.seq[i]
				break
			end
		end

		local alpha = 0
		local diff = f2.Time - f1.Time
		if diff > 0 then alpha = (self.time - f1.Time) / diff end
		alpha = math.clamp(alpha, 0, 1)

		local weight = math.clamp(elap / fDur, 0, 1)

		for joint, d1 in pairs(f1.Data) do
			local motor = fMotor(joint, self.map, self.low)
			if motor then
				local d2 = f2.Data[joint] or d1
				pcall(function()
					local target = d1.CFrame:Lerp(d2.CFrame, alpha)
					local start = init[motor.Name] or CFrame.new()
					motor.Transform = start:Lerp(target, weight)
				end)
			end
		end
	end)
end

function APlay:Stop(restore)
	self.playing = false
	if self.conn then self.conn:Disconnect() self.conn = nil end
	if restore then
		for _, m in pairs(self.map) do
			pcall(function() m.Transform = CFrame.new() end)
		end
	end
end

