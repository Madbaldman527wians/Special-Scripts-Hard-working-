					task.wait(0.05)
					TS:Create(cRoot, TweenInfo.new(0.8, Enum.EasingStyle.Cubic), {CFrame = cRoot.CFrame + cRoot.CFrame.LookVector * 1}):Play()
				end)
				task.wait(0.8)
			else
				task.wait(0.3)
				conn:Disconnect()
			end
		else
			task.wait(0.3)
			conn:Disconnect()
		end
		
		for _, part in ipairs(rig:GetDescendants()) do
			if part:IsA("BasePart") then part.Anchored = true end
