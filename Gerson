		local rig = tChar:Clone()
		for _, child in ipairs(rig:GetDescendants()) do
			if child:IsA("LocalScript") or child:IsA("Script") then
				child:Destroy()
			elseif child:IsA("BasePart") then
				child.Transparency = child.Transparency + 0.2
				child.CanCollide, child.CanQuery, child.CanTouch = false, false, false
			end
		end
		
		local cRoot = rig:FindFirstChild("HumanoidRootPart")
