local function cHit(range, box, isFinal)
	local op = OverlapParams.new()
	op.FilterType = Enum.RaycastFilterType.Exclude
	op.FilterDescendantsInstances = {char}
	
	local parts = workspace:GetPartBoundsInBox(root.CFrame * CFrame.new(0, 0, -range), box, op)
	local targets = {}
	for _, part in ipairs(parts) do
		local tc = part.Parent
		if tc and tc:FindFirstChild("Humanoid") and tc:FindFirstChild("HumanoidRootPart") then
			if not targets[tc] then
				targets[tc] = true
				sHit(tc.HumanoidRootPart, isFinal)
			end
		end
	end
end

