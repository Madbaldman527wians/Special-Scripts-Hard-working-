	camCF.Size, camCF.Transparency, camCF.Anchored, camCF.CanCollide = Vector3.new(1, 1, 1), 1, true, false
	camCF.CFrame = root.CFrame
	camCF.Parent = workspace
	
	sTele(char, root.CFrame, 1.2, 2.5)
	cam.CameraSubject = camCF
	
	local targetPos = tRoot.Position
	local tLook = tRoot.CFrame.LookVector
	local teleCF = CFrame.new(targetPos - (tLook * 3.5), targetPos)
	
	root.CFrame = CFrame.new(0, 1e10, 0)
	task.wait(0.35)
	
	camCF.CFrame = teleCF
	sTele(char, teleCF, 1.2, 2.5)
	task.wait(0.1)
	
	root.CFrame = teleCF
	cam.CameraSubject = hum
	camCF:Destroy()

	local speed = 3.6
	local totalHits = 3
	
	for strike = 1, totalHits do
		if not isSpec then break end
		local trk = pAnim(Anims.HammerSmash, speed, false, false, 0.1)
		task.spawn(pSlash, "Move1", 1.8)
		
		local isFinal = (strike == totalHits)
		task.delay(0.1, function()
			sHit(tRoot, isFinal)
			if isFinal then sCrack(tRoot.CFrame * CFrame.new(0, -2, 0)) end
		end)
		task.wait(trk.length / speed)
		trk:Stop(true)
	end
	
	isSpec = false
	setLock(false)
	cState = "Dummy"
	updMov(hum.MoveDirection.Magnitude)
end

local function doRun()
	if isAtk or isSpec then return end
	if tick() - lSpec2 < 3.0 then return end
	
	isSpec = true
	lSpec2 = tick()
	setLock(true)
	
	local shower = plr.PlayerGui:FindFirstChild("UI") and plr.PlayerGui.UI:FindFirstChild("Ui") and plr.PlayerGui.UI.Ui:FindFirstChild("MoveDebounceShower")
	local movesList = shower and shower:FindFirstChild("Moves1")
	if movesList and movesList:FindFirstChild("2") then
		task.spawn(applyUIDebounce, movesList["2"], 3.0)
	end
	
	local speed = 1.1
	local trk = pAnim(Anims.AtkStart, speed, false, true, 0.15)
	
	local att, lv = nil, nil
	local hit, hRoot = false, nil
	
	task.delay((15 / 30) / speed, function()
		if not isSpec or not trk.playing then return end
		local dir = root.CFrame.LookVector
		dir = Vector3.new(dir.X, 0, dir.Z).Unit
		
		att = Instance.new("Attachment")
		att.Parent = root
		
		lv = Instance.new("LinearVelocity")
		lv.MaxForce, lv.VelocityConstraintMode = 15000, Enum.VelocityConstraintMode.Vector
		lv.VectorVelocity = dir * 120
		lv.Attachment0 = att
		lv.Parent = root
	end)
	
	local runT = trk.length / speed
	local elap = 0
	while elap < runT and not hit and isSpec do
		local dt = task.wait(0.02)
		elap = elap + dt
		
		if lv then
			local op = OverlapParams.new()
			op.FilterType = Enum.RaycastFilterType.Exclude
			op.FilterDescendantsInstances = {char}
			local parts = workspace:GetPartBoundsInBox(root.CFrame * CFrame.new(0, 0, -3), Vector3.new(5, 5, 5), op)
			for _, part in ipairs(parts) do
				local tc = part.Parent
				if tc and tc:FindFirstChild("Humanoid") and tc:FindFirstChild("HumanoidRootPart") then
					hit, hRoot = true, tc.HumanoidRootPart
					break
				end
			end
		end
	end
	
	if lv then lv:Destroy() end
	if att then att:Destroy() end
	trk:Stop(false)
	
	if not isSpec then return end
	
	if hit and hRoot then
		local hit1Trk = pAnim(Anims.Hit1, 1, false, false, 0.1)
		task.spawn(pSlash, "Move4", 1.5)
		sHit(hRoot, false)
		task.spawn(sGlitch, char, root, hRoot, "Swing1")
		
		task.wait(hit1Trk.length / 2)
		hit1Trk:Stop(false)
		
		if isSpec then
			local hit2Trk = pAnim(Anims.Hit2, 2, false, false, 0.1)
			task.spawn(pSlash, "Light3", 1.5)
			
			task.delay(0.2, function() if hRoot then sHit(hRoot, true) end end)
			task.delay(10 / 30, function()
				if hRoot then sCrack(hRoot.CFrame * CFrame.new(0, -2, 0)) end
			end)
			
			task.wait(hit2Trk.length / 2)
			hit2Trk:Stop(true)
		end
	end
	
	isSpec = false
	setLock(false)
	cState = "Dummy"
	updMov(hum.MoveDirection.Magnitude)
end

local function doBuster()
	if isAtk or isSpec then return end
	if tick() - lBuster < 4.0 then return end
	
	isSpec = true
	lBuster = tick()
	setLock(true)
	
	local shower = plr.PlayerGui:FindFirstChild("UI") and plr.PlayerGui.UI:FindFirstChild("Ui") and plr.PlayerGui.UI.Ui:FindFirstChild("MoveDebounceShower")
	local movesList = shower and shower:FindFirstChild("Moves1")
	if movesList and movesList:FindFirstChild("3") then
		task.spawn(applyUIDebounce, movesList["3"], 4.0)
	end
	
	local speed = 1.2
	local trk = pAnim(Anims.RudeBuster, speed, false, false, 0.1)
	
	task.delay(0.15, function()
		local targetMC, targetRT = getMouse()
		local endPos = targetRT and targetRT.Position or (root.CFrame * CFrame.new(0, 0, -60)).Position
		
		local projectileModel = RudeBusterModel:Clone()
		local startCF = root.CFrame * CFrame.new(0, 0, -3)
		
		if projectileModel:IsA("Model") then
			projectileModel:PivotTo(startCF)
		elseif projectileModel:IsA("BasePart") then
			projectileModel.CFrame = startCF
		end
		
		projectileModel.Parent = workspace
		
		local pPart = projectileModel:FindFirstChild("RudeBuster") 
			or projectileModel.PrimaryPart 
			or (projectileModel:IsA("BasePart") and projectileModel)
			or projectileModel:FindFirstChildWhichIsA("BasePart")
			
		if pPart then
			pPart.Anchored = false
			local bodyVelocity = Instance.new("BodyVelocity")
			bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
			bodyVelocity.Velocity = (endPos - pPart.Position).Unit * 100
			bodyVelocity.Parent = pPart
		end
		
		eParts(projectileModel)
		
		task.spawn(function()
			local hitDetected = false
			local elapsed = 0
			local hitTarget = nil
			
			while elapsed < 2.5 and not hitDetected do
				local dt = task.wait(0.03)
				elapsed = elapsed + dt
				
				if projectileModel and projectileModel.Parent then
					local op = OverlapParams.new()
					op.FilterType = Enum.RaycastFilterType.Exclude
					op.FilterDescendantsInstances = {char, projectileModel}
					
					local modelPivot = projectileModel:IsA("Model") and projectileModel:GetPivot() or projectileModel.CFrame
					local parts = workspace:GetPartBoundsInBox(modelPivot, Vector3.new(5, 5, 5), op)
					for _, part in ipairs(parts) do
						local tc = part.Parent
						if tc and tc:FindFirstChild("Humanoid") and tc:FindFirstChild("HumanoidRootPart") then
							hitTarget = tc.HumanoidRootPart
							hitDetected = true
							break
						end
					end
				else
					break
				end
			end
			
			local explodeCF = CFrame.new(endPos)
			if projectileModel then 
				explodeCF = projectileModel:IsA("Model") and projectileModel:GetPivot() or projectileModel.CFrame
				projectileModel:Destroy() 
			end
			
			local expTemplate = VFX:FindFirstChild("RudeBusterExplode") and VFX["RudeBusterExplode"]:FindFirstChild("RudeBusterExplosion")
			if expTemplate then
				local expClone = expTemplate:Clone()
				if expClone:IsA("Model") then
					expClone:PivotTo(explodeCF)
				elseif expClone:IsA("BasePart") then
					expClone.CFrame = explodeCF
				end
				expClone.Parent = workspace
				eParts(expClone)
				Debris:AddItem(expClone, 3)
			end
			
			if hitTarget then
				sHit(hitTarget, true)
				sCrack(hitTarget.CFrame * CFrame.new(0, -2, 0))
			else
				sCrack(explodeCF * CFrame.new(0, -2, 0))
			end
		end)
	end)
	
	task.wait(trk.length / speed)
	trk:Stop(true)
	
	isSpec = false
	setLock(false)
	cState = "Dummy"
	updMov(hum.MoveDirection.Magnitude)
end

