local function eParts(model)
	for _, child in ipairs(model:GetDescendants()) do
		if child:IsA("ParticleEmitter") then
			task.spawn(function()
				local delayVal = child:GetAttribute("EmitDelay")
				local durationVal = child:GetAttribute("EmitDuration")
				local countVal = child:GetAttribute("EmitCount")
				
				if delayVal then task.wait(delayVal) end
				child:Emit(tonumber(countVal) or 15)
				
				if durationVal then
