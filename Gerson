	if tick() - lSpec1 < 3.0 then return end
	
	if not lockedTarget or not lockedTarget:FindFirstChild("HumanoidRootPart") then
		return
	end
	
	local tRoot = lockedTarget.HumanoidRootPart
	local tModel = lockedTarget
	
