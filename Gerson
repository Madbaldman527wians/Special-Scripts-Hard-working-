local ComboSlashNames = { [1] = "Light1", [2] = "Light2", [3] = nil, [4] = "Light5", [5] = "Light4" }

local function doAtk()
	if isAtk or isSpec then return end
	isAtk = true
	
	if tick() - lAtk > 3.0 then cCombo = 1 end
	setLock(true)
	
	local anim = Anims.Combo[cCombo]
	if anim then
		local speed = 1
		local trk = pAnim(anim, speed, false, false, 0.1)
		local slash = ComboSlashNames[cCombo]
		if slash then task.spawn(pSlash, slash, nil) end
		
		local final = (cCombo == 5)
		task.delay(0.12, function() cHit(4, Vector3.new(6, 5, 6), final) end)
		task.wait(trk.length / speed)
		trk:Stop(true)
	end
	
	lAtk = tick()
	cCombo = (cCombo % #Anims.Combo) + 1
	isAtk = false
	setLock(false)
	cState = "Dummy"
	updMov(hum.MoveDirection.Magnitude)
end

local function getMouse()
	local mouse = plr:GetMouse()
	local target = mouse.Target
	if target then
		local model = target:FindFirstAncestorOfClass("Model")
		if model and model ~= char then
			local tHum = model:FindFirstChildOfClass("Humanoid")
			local tRoot = model:FindFirstChild("HumanoidRootPart")
			if tHum and tRoot and tHum.Health > 0 then return model, tRoot end
		end
	end
	return nil, nil
end

-- Sistema de Manipulação Visual de Cooldowns na Nova UI (Corrigido com os caminhos solicitados)
local function applyUIDebounce(slotFrame, cooldownTime)
	if not slotFrame then return end
	local cooldownLabel = slotFrame:FindFirstChild("CooldownLabel") or Instance.new("TextLabel")
	if not cooldownLabel.Parent then
		cooldownLabel.Name = "CooldownLabel"
		cooldownLabel.Size = UDim2.new(1, 0, 1, 0)
		cooldownLabel.BackgroundTransparency = 0.4
		cooldownLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		cooldownLabel.TextColor3 = Color3.fromRGB(255, 255, 255)		
		cooldownLabel.FontFace = Font.new(
			"rbxasset://fonts/families/PressStart2P.json",
			Enum.FontWeight.Regular,
			Enum.FontStyle.Normal
		)
		cooldownLabel.TextSize = 28
		cooldownLabel.ZIndex = 10
		cooldownLabel.Parent = slotFrame
	end
	
	cooldownLabel.Visible = true
	local start = tick()
	while tick() - start < cooldownTime do
		local rem = cooldownTime - (tick() - start)
		cooldownLabel.Text = string.format("%.1f", rem)
		task.wait(0.05)
	end
	cooldownLabel.Visible = false
end

local function doSmash()
