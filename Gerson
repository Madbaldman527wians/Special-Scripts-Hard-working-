local function pSound(id, parent, vol, pitch)
	if not parent or not id then return end
	local snd = Instance.new("Sound")
	snd.SoundId = id
	snd.Volume = vol or 1
	snd.PlaybackSpeed = pitch or 1
	snd.RollOffMode = Enum.RollOffMode.InverseTapered
	snd.RollOffMinDistance, snd.RollOffMaxDistance = 10, 100
