local sThreads = {}

local function pSlash(name, mult)
	local model = S_Eff:Clone()
	local sPart = model:FindFirstChild("SlashPart")
	if not sPart then model:Destroy() return end
	
	local mesh = sPart:FindFirstChildOfClass("SpecialMesh")
	local scale = char:GetScale()
	local d = SData[name]
	
	if d and mesh and next(d) ~= nil then
		model:ScaleTo(scale * (mult or 1.2))
		if d.color then mesh.VertexColor = d.color end
		model:PivotTo(char:GetPivot())
		
		local weld = sPart:FindFirstChild("Weld")
		if weld then
			weld.Part0 = root
			weld.C0 = d.startAngle
		end
		
		sPart.Transparency = 1
		model.Parent = workspace
		
		if sThreads[sPart] then
			task.cancel(sThreads[sPart])
			sThreads[sPart] = nil
		end
		
		Debris:AddItem(model, 3)
		if d.delayTime and d.delayTime > 0 then task.wait(d.delayTime) end
		
		if not char:GetAttribute("Hit") then
			sPart.Transparency = 0.05
			sThreads[sPart] = task.spawn(function()
				for i = 1, #STexs do
					if not sPart or not sPart.Parent or not mesh then break end
					mesh.TextureId = STexs[i]
					if weld and weld.Parent then
						weld.C0 = weld.C0 * CFrame.Angles(0, math.rad(-d.speed), 0)
					end
					task.wait(0.03)
				end
				if model and model.Parent then model:Destroy() end
				sThreads[sPart] = nil
			end)
		else
			model:Destroy()
		end
	else
		model:Destroy()
	end
end

